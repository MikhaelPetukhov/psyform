# ================================================================
#                Psy-booking Environment Variables
# ================================================================
#
# This file serves as a template for the required .env file.
# Copy this file to .env in the same directory (`/backend`) and
# fill in the values for your local development environment.
#
# ----------------------------------------------------------------
# Security - IMPORTANT!
# ----------------------------------------------------------------
# Replace with your own long, random, and secret string.
# This is used for signing JWT tokens.
JWT_SECRET=your_super_secret_jwt_key
# Optional separate secret used as pepper for hashing one-time Telegram codes
AUTH_CODE_SECRET=
#
# ----------------------------------------------------------------
# Admin Credentials
# ----------------------------------------------------------------
# Default credentials for the psychologist's admin panel.
# It is highly recommended to change the password.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password
#
# ----------------------------------------------------------------
# Database Connection (PostgreSQL)
# ----------------------------------------------------------------
# Credentials for connecting to your local PostgreSQL database.
# These must match your local PostgreSQL setup.
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=psybooking
#
# The DATABASE_URL is constructed from the variables above.
# The format is: postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>
DATABASE_URL=postgres://postgres:password@localhost:5432/psybooking
#
#
# Telegram Bot credentials (optional)
# Get these from BotFather on Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Telegram API credentials for lookup service
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
# One-time login codes TTL in minutes (default 10)
AUTH_CODE_TTL_MIN=10
# Timezone for reminder messages formatting
TIMEZONE=Europe/Moscow
# Require client auth for public booking creation
REQUIRE_CLIENT_AUTH=false
# Base URL to generate simple meet links like <MEET_BASE_URL>/<bookingId>
MEET_BASE_URL=
#
# ----------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------
# The port the backend server will run on.
PORT=5000
# Allowed CORS origin for frontend
CORS_ORIGIN=http://localhost:3001
