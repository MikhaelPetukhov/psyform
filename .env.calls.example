# L2: Jitsi + TURN (локальный стенд)
# Переименуйте в .env.calls и заполните секреты. Не коммитьте реальные секреты.

# --- Версии образов ---
JITSI_TAG=stable-8719          # зафиксированная стабильная версия docker-jitsi-meet
COTURN_TAG=4.6.2               # coturn
TZ=Europe/Moscow

# --- Публичный URL Jitsi Web (локально) ---
# Используем mkcert/self-signed. 8443 проброшен на контейнерный 443.
PUBLIC_URL=https://jitsi.localhost:8443

# --- JWT для Jitsi (должны совпасть с генерацией токенов в backend) ---
# app_id/secret используются prosody для проверки подписи
JITSI_JWT_APP_ID=psyform-backend            # обычно совпадает с iss
JITSI_JWT_APP_SECRET=please-change-me       # секрет для подписи JWT (HS256)
# Разрешённые значения issuer/audience
JITSI_JWT_ISS=psyform-backend
JITSI_JWT_AUD=psyform-calls

# --- XMPP домены (оставьте по умолчанию, если не понимаете зачем менять) ---
JITSI_XMPP_DOMAIN=meet.jitsi
JITSI_XMPP_AUTH_DOMAIN=auth.meet.jitsi
JITSI_XMPP_MUC_DOMAIN=muc.meet.jitsi

# --- Гости без токена ---
ENABLE_GUESTS=0  # 0 = запрещено заходить без JWT

# --- JVB / хост ---
# Для NAT: адрес хоста, с которого доступен порт UDP 10000 (локально: host.docker.internal)
DOCKER_HOST_ADDRESS=host.docker.internal

# --- TURN (coturn) ---
# Статические креды для простоты локального стенда (в проде используйте REST-авторизацию/secret)
TURN_STATIC_USER=turnuser
TURN_STATIC_PASSWORD=turnpassword
TURN_REALM=jitsi.localhost
# Внешний IP для coturn (локально можно указать IP вашей машины в сети: 192.168.x.x)
COTURN_EXTERNAL_IP=192.168.0.10
# Хост/DNS для объявления TURN в Jitsi (может совпадать с IP выше или доменом)
COTURN_PUBLIC_HOST=192.168.0.10

# --- Сертификаты ---
# Поместите файлы TLS в каталог ./calls/certs как tls.crt и tls.key (см. docs/calls/l2-compose.md).
# Пример с mkcert: `mkcert -cert-file .\\calls\\certs\\tls.crt -key-file .\\calls\\certs\\tls.key jitsi.localhost 127.0.0.1`

